1161 0 obj
<</S /JavaScript /JS (function _FindWords\(pageIndex, keys\){this.selectPageNthWord\(pageIndex, 0, bScroll=false\);\r\nvar numWords   = this.getPageNumWords\(pageIndex\);\r\nvar startIndex = 0\r\nfor \(var nWord = 0; nWord < numWords; nWord++\)\r\n{\r\n    var foundWord = true;\r\n    for \(var i = 0; i < keys.length; i++\) {\r\n        var matchWord = this.getPageNthWord\(pageIndex, nWord + i, false\);\r\n        matchWord     = matchWord.replace\(/^\\s*|\\s*$/g,""\);\r\n        if \(matchWord != keys[i]\) {\r\n            foundWord = false;\r\n            break;\r\n        }\r\n    }\r\n    if \(foundWord \) {\r\n        this.selectPageNthWord\(pageIndex, nWord, bScroll=false\);\r\n        break;\r\n    }\r\n}}) 
>>
